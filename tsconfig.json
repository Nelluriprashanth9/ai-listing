{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["web/**/*"]
}
